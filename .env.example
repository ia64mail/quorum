# === Application (all apps) ===
PORT=3000
NODE_ENV=development

# === Anthropic LLM API (agents only) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Moderator Subscription Auth (moderator only, QRM7-013) ===
# Long-lived OAuth token for headless moderator auth. Issued by running
# `claude setup-token` inside the moderator container; requires a Claude.ai
# Pro/Max/Team/Enterprise subscription seat. Preserves flat-rate billing
# established in QRM7-007. See tickets/QRM7-013-moderator-oauth-refresh-on-idle.md.
CLAUDE_CODE_OAUTH_TOKEN=
# NOTE: Token pricing for moderator cost tracking is hardcoded per model
# in apps/terminal/src/llm/pricing.ts — update if changing ANTHROPIC_MODEL
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096

# === MCP Server Connectivity (terminal, agent) ===
MCP_SERVER_URL=http://mcp-server:3000

# === Agent Identity (agent only) ===
AGENT_ROLE=developer
AGENT_WORKSPACE_DIR=/mnt/quorum/workspace

# === Message Broker (mcp-server only) ===
BROKER_MAX_CALL_DEPTH=5
BROKER_DEFAULT_TIMEOUT_MS=300000

# === Context Store (mcp-server only) ===
CONTEXT_DEFAULT_MAX_TOKENS=2000
CONTEXT_TOKEN_CHAR_RATIO=4

# === Logging (all apps) ===
LOG_LEVEL=log
LOG_JSON_DIR=
LOG_CONSOLE=true

# === Docker Compose ===
# ANTHROPIC_API_KEY must be set in .env for docker compose
# WORKSPACE_PATH — host path mounted into agent containers
WORKSPACE_PATH=/path/to/target/project